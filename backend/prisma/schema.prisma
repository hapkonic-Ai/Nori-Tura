generator client {
  provider = "prisma-client-py"
  output   = "."
  interface = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model doctors {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  hospital_id String?
  specialty   String
  is_active   Boolean  @default(false)
  fcm_token   String?
  platform    String?
  created_at  DateTime @default(now())

  hospital        hospitals?         @relation(fields: [hospital_id], references: [id])
  patients        patients[]
  opd_records     opd_records[]
  ipd_admissions  ipd_admissions[]
  appointments    appointments[]
  documents       documents[]
  whatsapp_logs   whatsapp_logs[]
  nurses          nurses[]
  consent_forms   consent_forms[]
  ai_diagnosis_logs ai_diagnosis_logs[]
  surgical_templates surgical_templates[]

  @@index([hospital_id])
}

model nurses {
  id          String   @id @default(uuid())
  doctor_id   String
  name        String
  phone       String   @unique
  hospital_id String?
  fcm_token   String?
  platform    String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  doctor      doctors   @relation(fields: [doctor_id], references: [id])
  hospital    hospitals? @relation(fields: [hospital_id], references: [id])

  @@index([doctor_id])
  @@index([hospital_id])
}

model admins {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  role       String   // superadmin | admin
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model hospitals {
  id                  String   @id @default(uuid())
  name                String
  logo_url            String?
  address             String?
  contact             String?
  registration_number String?
  created_at          DateTime @default(now())

  doctors        doctors[]
  nurses         nurses[]
  patients       patients[]
  opd_records    opd_records[]
  ipd_admissions ipd_admissions[]
  documents      documents[]
  consent_forms  consent_forms[]

  @@index([name])
}

model patients {
  id           String   @id @default(uuid())
  doctor_id    String
  hospital_id  String?
  name         String
  age          Int
  gender       String
  blood_group  String?
  allergies    String?
  parent_name  String
  parent_phone String
  fcm_token    String?
  platform     String?
  created_at   DateTime @default(now())

  doctor        doctors         @relation(fields: [doctor_id], references: [id])
  hospital      hospitals?      @relation(fields: [hospital_id], references: [id])
  opd_records   opd_records[]
  ipd_admissions ipd_admissions[]
  appointments  appointments[]
  documents     documents[]
  whatsapp_logs whatsapp_logs[]
  consent_forms consent_forms[]

  @@index([doctor_id])
  @@index([hospital_id])
}

model opd_records {
  id                       String     @id @default(uuid())
  patient_id               String
  doctor_id                String
  nurse_id                 String?
  hospital_id              String?
  hospital_name            String?
  hospital_logo_url        String?
  created_by               String     @default("surgeon")
  review_status            String     @default("reviewed")
  visit_type               String
  complaint                String
  examination              String
  diagnosis                String?
  surgical_decision        String?
  planned_procedure        String?
  advice                   String?
  follow_up_date           DateTime?
  reminder_sent            Boolean    @default(false)
  prescription_image_urls  String[]
  created_at               DateTime   @default(now())

  patient           patients @relation(fields: [patient_id], references: [id])
  doctor            doctors  @relation(fields: [doctor_id], references: [id])
  hospital          hospitals? @relation(fields: [hospital_id], references: [id])
  medications       medications[]
  investigations    investigations[]
  ai_diagnosis_logs ai_diagnosis_logs[]

  @@index([doctor_id])
  @@index([patient_id])
  @@index([hospital_id])
}

model medications {
  id             String @id @default(uuid())
  opd_record_id  String
  name           String
  dose           String
  frequency      String
  duration       String
  
  opd_record     opd_records @relation(fields: [opd_record_id], references: [id])
  
  @@index([opd_record_id])
}

model investigations {
  id             String @id @default(uuid())
  opd_record_id  String
  type           String
  status         String @default("pending")
  
  opd_record     opd_records @relation(fields: [opd_record_id], references: [id])
  
  @@index([opd_record_id])
}

model ipd_admissions {
  id                String   @id @default(uuid())
  patient_id        String
  doctor_id         String
  hospital_id       String?
  hospital_name     String?
  hospital_logo_url String?
  bed_no            String?
  ward              String?
  admitted_at       DateTime @default(now())
  discharge_at      DateTime?
  urgency           String
  consent_status    String   @default("pending")
  status            String   @default("admitted")

  patient             patients           @relation(fields: [patient_id], references: [id])
  doctor              doctors            @relation(fields: [doctor_id], references: [id])
  hospital            hospitals?         @relation(fields: [hospital_id], references: [id])
  pre_op_notes        pre_op_notes[]
  intra_op_notes      intra_op_notes[]
  post_op_notes       post_op_notes[]
  ward_round_notes    ward_round_notes[]
  discharge_summaries discharge_summaries[]
  consent_forms       consent_forms[]

  @@index([doctor_id])
  @@index([patient_id])
  @@index([hospital_id])
}

model pre_op_notes {
  id                   String   @id @default(uuid())
  admission_id         String   @unique
  procedure            String
  approach             String?
  anaesthesia          String?
  investigations       String[]
  risk_level           String?
  special_instructions String?
  image_urls           String[]
  completed_at         DateTime?

  admission ipd_admissions @relation(fields: [admission_id], references: [id])

  @@index([admission_id])
}

model intra_op_notes {
  id              String   @id @default(uuid())
  admission_id    String
  procedure_done  String
  findings        String?
  technique       String?
  complications   String?
  blood_loss      String?
  ot_start        DateTime?
  ot_end          DateTime?
  image_urls      String[]
  video_urls      String[]
  created_at      DateTime @default(now())

  admission ipd_admissions @relation(fields: [admission_id], references: [id])

  @@index([admission_id])
}

model post_op_notes {
  id                String   @id @default(uuid())
  admission_id      String
  day_number        Int
  condition         String
  vitals_json       Json
  wound_status      String?
  pain_score        Int?
  diet              String?
  medications_json  Json?
  image_urls        String[]
  created_at        DateTime @default(now())

  admission ipd_admissions @relation(fields: [admission_id], references: [id])

  @@index([admission_id])
}

model ward_round_notes {
  id                  String   @id @default(uuid())
  admission_id        String
  nurse_id            String?
  round_date          DateTime @default(now())
  subjective          String?
  objective           String?
  assessment          String?
  plan                String?
  ready_for_discharge Boolean  @default(false)
  image_urls          String[]
  created_at          DateTime @default(now())

  admission ipd_admissions @relation(fields: [admission_id], references: [id])

  @@index([admission_id])
}

model discharge_summaries {
  id                         String   @id @default(uuid())
  admission_id               String   @unique
  condition_at_discharge     String
  procedure_summary          String
  discharge_medications_json Json
  wound_care                 String?
  activity_restrictions      String?
  diet_instructions          String?
  follow_up_date             DateTime?
  red_flags                  String?
  image_urls                 String[]
  created_at                 DateTime @default(now())

  admission ipd_admissions @relation(fields: [admission_id], references: [id])

  @@index([admission_id])
}

model appointments {
  id            String   @id @default(uuid())
  patient_id    String
  doctor_id     String
  slot_datetime DateTime
  visit_type    String
  procedure     String?
  urgency       String?
  status        String   @default("booked")
  booked_by     String   @default("parent")
  created_at    DateTime @default(now())
  
  patient patients @relation(fields: [patient_id], references: [id])
  doctor  doctors  @relation(fields: [doctor_id], references: [id])
  
  @@index([doctor_id])
  @@index([patient_id])
}

model documents {
  id               String   @id @default(uuid())
  patient_id       String
  doctor_id        String
  hospital_id      String?
  name             String
  url              String
  type             String
  category         String?
  uploaded_by_role String   @default("surgeon")
  recorded_at      DateTime @default(now())
  uploaded_at      DateTime @default(now())

  patient patients   @relation(fields: [patient_id], references: [id])
  doctor  doctors    @relation(fields: [doctor_id], references: [id])
  hospital hospitals? @relation(fields: [hospital_id], references: [id])

  @@index([patient_id])
  @@index([doctor_id])
  @@index([hospital_id])
}

model whatsapp_logs {
  id           String   @id @default(uuid())
  patient_id   String
  doctor_id    String
  trigger_type String
  message_body String
  sent_at      DateTime @default(now())
  status       String
  
  patient patients @relation(fields: [patient_id], references: [id])
  doctor  doctors  @relation(fields: [doctor_id], references: [id])
  
  @@index([doctor_id])
  @@index([patient_id])
}

model otp_sessions {
  id         String   @id @default(uuid())
  phone      String
  otp_hash   String
  role       String?
  expires_at DateTime
  verified   Boolean  @default(false)
  created_at DateTime @default(now())
  
  @@index([phone])
}

model consent_forms {
  id                         String    @id @default(uuid())
  admission_id               String
  patient_id                 String
  doctor_id                  String
  form_type                  String
  content_json               Json
  pdf_url                    String?
  signed_pdf_url             String?
  parent_signature_url       String?
  witness_name               String?
  witness_signature_url      String?
  generated_at               DateTime  @default(now())
  signed_at                  DateTime?
  generated_by               String    @default("surgeon")
  status                     String    @default("pending")

  // Enhanced consent metadata and compliance fields
  consent_number             String?   @unique
  version                    String    @default("v2.1")
  language                   String    @default("English")
  guardian_relationship      String?
  witness_relationship       String?
  witness_mobile             String?
  pdf_hash                   String?
  signed_pdf_hash            String?

  // Hospital information
  hospital_id                String?
  hospital_name              String?
  hospital_address           String?
  hospital_contact           String?
  hospital_registration_number String?
  hospital_logo_url          String?

  // Department / ward context
  department                 String?

  // Doctor information (denormalised for the consent record)
  doctor_qualification       String?
  doctor_registration_number String?

  // Clinical information (also present in content_json; mirrored for queryability)
  diagnosis                  String?
  procedure_description      String?
  expected_recovery          String?
  possible_complications     String?
  material_risks             String?

  admission ipd_admissions @relation(fields: [admission_id], references: [id])
  patient   patients        @relation(fields: [patient_id], references: [id])
  doctor    doctors         @relation(fields: [doctor_id], references: [id])
  hospital  hospitals?      @relation(fields: [hospital_id], references: [id])

  @@index([doctor_id])
  @@index([patient_id])
  @@index([admission_id])
  @@index([hospital_id])
  @@index([consent_number])
}

model ai_diagnosis_logs {
  id                 String   @id @default(uuid())
  opd_record_id      String
  doctor_id          String
  complaint          String
  examination        String
  age                Int
  gender             String
  suggestions_json   Json
  selected_diagnosis String?
  model_used         String
  created_at         DateTime @default(now())
  
  opd_record opd_records @relation(fields: [opd_record_id], references: [id])
  doctor     doctors     @relation(fields: [doctor_id], references: [id])
  
  @@index([doctor_id])
  @@index([opd_record_id])
}

model surgical_templates {
  id                   String   @id @default(uuid())
  doctor_id            String
  name                 String
  procedure            String
  approach             String?
  anaesthesia          String[]
  investigations       String[]
  risk_level           String?
  technique            String?
  special_instructions String?
  created_at           DateTime @default(now())
  
  doctor doctors @relation(fields: [doctor_id], references: [id])
  
  @@index([doctor_id])
}
